<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.EditarProduto"
             Title="Edição de Produto">
    
    <ScrollView> <!--Adicionado o Scroll-->
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Descrição"/>
            <Entry x:Name="txt_descricao"/>

            <Label Text="Quantidade"/>
            <Entry x:Name="txt_quantidade" Keyboard="Numeric"/>

            <Label Text="Preço"/>
            <Entry x:Name="txt_preco" Keyboard="Numeric"/>

            <!--Botões de confirmação-->
            <HorizontalStackLayout Spacing="10">
                
             <!--Botão para Salvar-->
            <Button Text="Salvar Alterações"
                    Clicked="btn_salvar_Clicked"
                    BackgroundColor="Green"
                    TextColor="White"/>

                <!--Botão para cancelar-->
            <Button Text="Cancelar"
                Clicked="btn_cancelar_Clicked"
                BackgroundColor="Red"
                TextColor="White"
                HorizontalOptions="FillAndExpand"/>
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>